{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cd ${workspaceFolder} && mkdir -p build && cd build && cmake -DCMAKE_BUILD_TYPE=Debug .. && make -j4",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "构建项目"
            
        },
        {
            "label": "清理构建",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/build",
            "problemMatcher": []
        }
    ]
}